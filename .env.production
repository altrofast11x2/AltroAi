# 이 파일은 "공개해도 안전한 값"만 담아 커밋됩니다. (Vercel 빌드 시 자동 주입)
# 🔒 진짜 비밀(OPENAI_API_KEY / ANTHROPIC_API_KEY)은 절대 여기 두지 말고
#    Vercel → Project → Settings → Environment Variables 에 등록하세요. (NEXT_PUBLIC_ 없이)

# Firebase 웹 설정 (공개값 — 보안은 database.rules.json 으로 강제). Altro 패밀리 공용.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAE9QENyt-zlVrfvmJ7sMzFyiCq6SE7qzw
NEXT_PUBLIC_FIREBASE_APP_ID=1:943741255139:web:7e48f6d2b421738dde74d6
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cozyboard-9fb1a.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://cozyboard-9fb1a-default-rtdb.asia-southeast1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=943741255139
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cozyboard-9fb1a
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cozyboard-9fb1a.firebasestorage.app

# AI 제공자 — Vercel 무료 배포는 Groq(OpenAI 호환). (이 3개는 비밀 아님 → 커밋 OK)
