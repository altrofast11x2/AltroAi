# ─────────────────────────────────────────────────────────────
#  AltroAi 환경변수 예시 — 실제 값 없이 "어떤 변수가 필요한지"만 문서화.
#  이 파일만 git 에 커밋되고, 실제 값이 든 .env.local / .env.production 은 제외된다.
#  사용법:  cp .env.example .env.local  후 값 채우기
# ─────────────────────────────────────────────────────────────

# Firebase 웹 설정 (브라우저 노출 OK — DB 보안은 database.rules.json 이 담당)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# AI 제공자: claude | openai | ollama. 미설정 시 키 유무로 자동 결정.
AI_PROVIDER=

# 🔒 (A) OpenAI 호환 (Groq=무료, Vercel ○) — 서버 전용. https://console.groq.com
OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# 🔒 (B) Claude (유료, Vercel ○) — 서버 전용 (절대 NEXT_PUBLIC_ 금지). https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# (C) Ollama (무료, 로컬 전용 — Vercel ✗) — 키 불필요. https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
